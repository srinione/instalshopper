# Copy to .env and fill in for local development.
# On Railway, set these as environment variables in the service settings.

# Postgres connection (Railway provides this automatically when you add a Postgres plugin)
# Locally: docker run -d --name pg -e POSTGRES_PASSWORD=pg -p 5432:5432 postgres:16
DATABASE_URL=postgres://postgres:pg@localhost:5432/postgres

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=instashopper2026

# JWT signing secret — use a long random string in production
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Secret for the cron endpoint (so only the cron worker can trigger fetches)
CRON_SECRET=change-me-to-another-long-random-string

# Anthropic API key — required for AI deal fetching
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model used for deal fetching
# Default: claude-haiku-4-5-20251001 (fastest, cheapest — perfect for this task)
# Options: claude-haiku-4-5-20251001, claude-sonnet-4-6, claude-opus-4-7
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# Your public URL (only needed for the cron worker)
PUBLIC_URL=https://your-app.up.railway.app

# Server port (Railway sets this automatically)
PORT=3000
